{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "completion_relay｜完成接力",
  "description": "完整交付、剩余工作、同步和完成真实性契约。",
  "type": "object",
  "required": ["required_output_inventory", "child_task_graph", "remaining_work_check", "completion_status", "git_closeout"],
  "properties": {
    "required_output_inventory": {"type": "array", "minItems": 1, "description": "必交付清单。"},
    "child_task_graph": {"type": "array", "minItems": 1, "description": "子任务图。"},
    "remaining_work_check": {"type": "object", "description": "剩余工作检查。"},
    "completion_status": {"type": "string", "description": "完成状态。"},
    "git_closeout": {"type": "object", "required": ["remote_match"], "properties": {"remote_match": {"type": "boolean"}}, "description": "Git 收尾证据。"}
  }
}
