{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "state_transition｜状态转换",
  "description": "状态更新前的证据和人工闸门契约。",
  "type": "object",
  "required": ["current_state", "target_state", "required_evidence", "human_gate_required", "human_gate_satisfied"],
  "properties": {
    "current_state": {"type": "string", "description": "当前状态。"},
    "target_state": {"type": "string", "description": "目标状态。"},
    "required_evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["evidence_type", "source_path", "readback_status"], "properties": {"evidence_type": {"type": "string"}, "source_path": {"type": "string"}, "readback_status": {"const": "read_ok"}}}, "description": "转换所需证据。"},
    "human_gate_required": {"type": "boolean", "description": "是否需要人工闸门。"},
    "human_gate_satisfied": {"type": "boolean", "description": "人工闸门是否满足。"}
  }
}
