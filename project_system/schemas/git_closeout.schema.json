{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "git_closeout｜Git 收尾",
  "description": "精确暂存、扫描、提交、推送、三方 SHA 与远端回读的验证契约。",
  "type": "object",
  "required": ["staged_paths", "authorized_staged_paths", "diff_check_passed", "secret_scan_passed", "sensitive_scan_passed", "commit_sha", "push_succeeded", "local_head", "origin_main", "ls_remote_main", "branch", "remote_readback", "repository_visibility", "contains_sensitive_business_data", "contains_personal_data"],
  "properties": {
    "staged_paths": {"type": "array", "minItems": 1, "description": "精确暂存路径。"},
    "authorized_staged_paths": {"type": "array", "minItems": 1, "description": "来自已验证单文件方案的可暂存路径。"},
    "diff_check_passed": {"type": "boolean", "description": "暂存 diff 检查。"},
    "secret_scan_passed": {"type": "boolean", "description": "秘密扫描。"},
    "sensitive_scan_passed": {"type": "boolean", "description": "Public 仓库敏感资料扫描。"},
    "commit_sha": {"type": "string", "description": "提交 SHA。"},
    "push_succeeded": {"type": "boolean", "description": "普通 push 是否成功。"},
    "local_head": {"type": "string", "description": "本地 HEAD。"},
    "origin_main": {"type": "string", "description": "origin/main。"},
    "ls_remote_main": {"type": "string", "description": "git ls-remote main。"},
    "branch": {"const": "main", "description": "正式主分支。"},
    "per_file_plan_path": {"type": "string", "description": "正式 live Git 收尾所回读的单文件方案路径。"},
    "repository_visibility": {"enum": ["Public", "Private"], "description": "任务声明；运行内核必须与正式安全状态对读。"},
    "contains_sensitive_business_data": {"type": "boolean", "description": "是否包含商业敏感数据；Public 或 Private 未授权时必须阻断。"},
    "contains_personal_data": {"type": "boolean", "description": "是否包含个人信息；任何可见性下均必须阻断。"},
    "contains_secret": {"type": "boolean", "description": "是否包含密钥或认证材料；任何可见性下均必须阻断。"},
    "sensitive_data_authorized": {"type": "boolean", "description": "Private 仓库商业敏感数据是否已获明确授权。"},
    "remote_readback": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "read_status"], "properties": {"path": {"type": "string"}, "read_status": {"const": "read_ok"}}}, "description": "远端关键文件可回读。"}
  }
}
