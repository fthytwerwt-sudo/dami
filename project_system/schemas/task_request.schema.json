{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "task_request｜任务交接契约",
  "description": "任何复杂或写入任务的必填交接字段。",
  "type": "object",
  "required": ["goal", "context", "source_of_truth", "constraints", "allowed_files", "forbidden_files", "external_actions", "human_gates", "execution_steps", "validation", "done_when", "blocked_if", "output", "task_type", "responsibility_layer", "must_read_files"],
  "properties": {
    "goal": {"type": "string", "description": "目标。"},
    "context": {"type": "string", "description": "上下文。"},
    "source_of_truth": {"type": "array", "description": "事实源。"},
    "constraints": {"type": "array", "description": "边界。"},
    "allowed_files": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "允许文件。"},
    "forbidden_files": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "禁止文件。"},
    "external_actions": {"description": "外部动作权限。"},
    "human_gates": {"type": "array", "description": "人工闸门。"},
    "task_type": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "任务类型。"},
    "responsibility_layer": {"type": "array", "minItems": 1, "items": {"type": "string"}, "description": "责任层级。"},
    "must_read_files": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "read_status"], "properties": {"path": {"type": "string"}, "read_status": {"enum": ["read_ok", "missing", "unreadable", "not_applicable"]}}}, "description": "必读文件与 read_status。"}
    ,"repository_write_requested": {"type": "boolean", "description": "是否计划写入仓库；为 true 时运行器强制完整写入契约。"}
    ,"implementation_design": {"description": "实现设计（Implementation design）。"}
    ,"impact_check": {"description": "影响面检查（Impact check）。"}
    ,"supply_pack": {"description": "执行前供料包（Supply pack）。"}
    ,"failure_routes": {"description": "失败路由（Failure routes）。"}
    ,"rollback": {"description": "回滚方案（Rollback）。"}
    ,"completion_relay": {"description": "完成接力（Completion Relay）。"}
    ,"git_closeout": {"description": "Git 收尾（Git closeout）。"}
    ,"workspace_mode": {"type": "string", "description": "单工作区模式声明。"}
    ,"external_workspace_required": {"type": "boolean", "description": "是否需要外部正式工作区。"}
    ,"worktree_requested": {"type": "boolean", "description": "是否请求 git worktree。"}
  }
}
